# Daikin Matter Bridge - environment configuration

# Gen5 HTTPS adapter local API key (raw value).
#DAIKIN_LOCAL_API_KEY=

# Alternative: read the key from a file instead.
#DAIKIN_LOCAL_API_KEY_FILE=/etc/daikin-matter/local_api_key

# Space-separated IPv4 addresses. Leave unset to auto-discover.
#DAIKIN_IP_ADDRS=192.168.1.150 192.168.1.151

# Persistent data directory.
#DAIKIN_DATA_DIR=/var/lib/daikin-matter

# Discovery timeout in milliseconds (default: 3000).
#DAIKIN_TIMEOUT=3000

# Stop discovery after this many devices (default: unlimited).
#DAIKIN_COUNT=
